rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Jobs Collection
    match /Jobs/{jobId} {
      // Allow a user to read their own job data
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      
      // Do not allow the client to create, update, or delete jobs directly.
      // All creation/mutation goes through the secure Cloud Functions workflow.
      allow create, update, delete: if false;
    }

  }
}
